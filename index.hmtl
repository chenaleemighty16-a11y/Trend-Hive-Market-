<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="style.css">
</head>
<body>
    <header id="hero-placeholder">
        <div class="video-placeholder">Video Header Coming Soon</div>
    </header>

    <nav class="filter-nav">
        <button id="filter-btn" class="pop-btn">Filter Products ▾</button>
        <div id="filter-dropdown" class="dropdown-content">
            <a href="#">Hoodies</a>
            <a href="#">Totes</a>
            <a href="#">Jewelry</a>
        </div>
    </nav>

    <main id="product-grid"></main>

    <footer>
        <div class="footer-content">
            <img src="images/group-photo.jpg" alt="Quillin Friends">
            <p>Thank you for stopping by! Remember: Life's too short for boring stuff.</p>
            <div class="socials">
                <a href="#">Instagram</a> | <a href="#">TikTok</a>
            </div>
        </div>
    </footer>

    <script src="script.js"></script>
</body>
</html>
